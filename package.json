{
  "name": "watchdog-agent-control",
  "version": "0.0.1",
  "private": true,
  "description": "Local operator control plane for agentic loops and subagents.",
  "type": "module",
  "bin": {
    "watchdog": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dashboard": "bun run web:build && tsx src/cli.ts dashboard",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "build": "bun run web:build && tsup src/cli.ts --format esm --dts --clean --out-dir dist",
    "check": "tsc --noEmit",
    "test": "vitest run src web/src",
    "test:web": "playwright test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sirv": "^3.0.2",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^6.0.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^8.1.4",
    "vitest": "^3.1.2"
  }
}
